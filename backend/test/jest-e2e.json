{
  "rootDir": "../src",
  "moduleFileExtensions": ["js", "json", "ts"],
  "modulePathIgnorePatterns": ["<rootDir>/__mocks__"],
  "setupFiles": ["../test/setup-e2e-env.js"],
  "setupFilesAfterEnv": ["../test/matcher-extensions", "../test/setup-silent-console"],
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "testTimeout": 60000,
  "transform": {
    "^.+\\.(t|j)s$": "@swc/jest"
  },
  "transformIgnorePatterns": [
    "node_modules/(?!(.*\\.mjs$|@otplib|@scure|@noble|@faker-js))"
  ]
}
