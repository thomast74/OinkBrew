{
  "name": "oinkbrew-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "npm run export:env && nest start",
    "start:dev": "npm run export:env && nest start --watch",
    "start:debug": "npm run export:env && nest start --debug --watch",
    "start:prod": "node dist/main",
    "export:env": "export $(cat .env | grep -v '#' | grep -v -e '^$' | xargs)",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "npm run export:env && jest",
    "test:watch": "npm run export:env && jest --watch",
    "test:cov": "npm run export:env && jest --coverage",
    "test:debug": "npm run export:env && node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "npm-run-all --continue-on-error e2e:up e2e:run e2e:down",
    "e2e:up": "docker compose -f ../docker-compose-e2e.yml up -d && sleep 20",
    "e2e:down": "docker compose -f ../docker-compose-e2e.yml down --volumes",
    "e2e:run": "jest --ci --config ./test/jest-e2e.json --forceExit --detectOpenHandles --verbose"
  },
  "dependencies": {
    "@nestjs/bull": "11.0.4",
    "@nestjs/common": "11.1.13",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "11.1.13",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/mongoose": "11.0.4",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.13",
    "argon2": "0.44.0",
    "bull": "4.16.5",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.3",
    "date-fns": "4.1.0",
    "eventsource": "4.1.0",
    "iterate": "0.1.1",
    "mongoose": "9.1.6",
    "otplib": "13.2.1",
    "particle-api-js": "11.1.7",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "passport-local": "1.0.0",
    "qrcode": "1.5.4",
    "reflect-metadata": "0.2.2",
    "rimraf": "6.1.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@faker-js/faker": "10.3.0",
    "@nestjs/cli": "11.0.16",
    "@nestjs/schematics": "11.0.9",
    "@nestjs/testing": "11.1.13",
    "@swc/cli": "^0.7.0",
    "@swc/core": "1.15.11",
    "@swc/jest": "0.2.39",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/jest-when": "3.5.5",
    "@types/node": "^22.19.0",
    "@types/passport-jwt": "4.0.1",
    "@types/passport-local": "1.0.38",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.2.0",
    "jest-extended": "7.0.0",
    "jest-mock-extended": "4.0.0",
    "jest-when": "3.7.0",
    "mongodb-memory-server": "11.0.1",
    "npm-run-all": "4.1.5",
    "prettier": "^3.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "@swc/jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(.*\\.mjs$|@otplib|@scure|@noble))"
    ],
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "../test/setup-silent-console",
      "../test/matcher-extensions"
    ]
  }
}
